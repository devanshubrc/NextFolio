---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEOHead from '../components/seo/SEOHead.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Contact NextFolios',
  description: 'Get in touch with the NextFolios team for support, feedback, feature requests, or partnership inquiries.',
  url: 'https://nextfolios.com/contact',
};
---

<BaseLayout>
  <SEOHead
    slot="head"
    title="Contact Us - NextFolios"
    description="Reach out to the NextFolios team for support, feedback, feature requests, or partnership inquiries. We read every message and respond as quickly as we can."
    schema={schema}
  />

  <main id="main-content">
    <!-- Hero Section -->
    <section class="relative overflow-hidden pt-32 pb-16">
      <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
        <div class="absolute top-1/3 right-1/4 w-80 h-80 bg-[var(--color-accent-purple)] rounded-full opacity-5 blur-3xl"></div>
        <div class="absolute bottom-1/3 left-1/4 w-80 h-80 bg-[var(--color-accent-blue)] rounded-full opacity-5 blur-3xl"></div>
      </div>

      <div class="section-container relative z-10">
        <div class="max-w-3xl mx-auto text-center">
          <span class="badge mb-6">Contact</span>
          <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight mb-6">
            Let's <span class="gradient-text">talk</span>
          </h1>
          <p class="text-lg text-[var(--color-text-secondary)] max-w-2xl mx-auto leading-relaxed">
            Have a question, found a bug, or want to suggest a feature? We genuinely read every message and do our best to respond within 48 hours. Your feedback directly shapes what we build next.
          </p>
        </div>
      </div>
    </section>

    <!-- Contact Content -->
    <section class="py-16" id="contact-form-section">
      <div class="section-container">
        <div class="max-w-5xl mx-auto grid lg:grid-cols-5 gap-12">

          <!-- Contact Form -->
          <div class="lg:col-span-3">
            <div class="card p-8" id="contact-form-card">
              <h2 class="text-2xl font-bold text-[var(--color-text-primary)] mb-6">Send us a message</h2>

              <form id="contact-form" class="space-y-5" novalidate>
                <div>
                  <label for="contact-name" class="block text-sm font-medium text-[var(--color-text-secondary)] mb-2">
                    Full Name <span class="text-[var(--color-accent-pink)]">*</span>
                  </label>
                  <input
                    type="text"
                    id="contact-name"
                    name="name"
                    required
                    autocomplete="name"
                    placeholder="Your full name"
                    class="w-full px-4 py-3 bg-[var(--color-bg-tertiary)] border border-[var(--color-border-default)] rounded-xl text-[var(--color-text-primary)] placeholder:text-[var(--color-text-muted)] focus:outline-none focus:border-[var(--color-accent-blue)] focus:ring-1 focus:ring-[var(--color-accent-blue)] transition-colors duration-200"
                  />
                  <p id="contact-name-error" class="text-[var(--color-accent-pink)] text-xs mt-1 hidden">Please enter your name.</p>
                </div>

                <div>
                  <label for="contact-email" class="block text-sm font-medium text-[var(--color-text-secondary)] mb-2">
                    Email Address <span class="text-[var(--color-accent-pink)]">*</span>
                  </label>
                  <input
                    type="email"
                    id="contact-email"
                    name="email"
                    required
                    autocomplete="email"
                    placeholder="you@example.com"
                    class="w-full px-4 py-3 bg-[var(--color-bg-tertiary)] border border-[var(--color-border-default)] rounded-xl text-[var(--color-text-primary)] placeholder:text-[var(--color-text-muted)] focus:outline-none focus:border-[var(--color-accent-blue)] focus:ring-1 focus:ring-[var(--color-accent-blue)] transition-colors duration-200"
                  />
                  <p id="contact-email-error" class="text-[var(--color-accent-pink)] text-xs mt-1 hidden">Please enter a valid email address.</p>
                </div>

                <div>
                  <label for="contact-subject" class="block text-sm font-medium text-[var(--color-text-secondary)] mb-2">
                    Subject <span class="text-[var(--color-accent-pink)]">*</span>
                  </label>
                  <select
                    id="contact-subject"
                    name="subject"
                    required
                    class="w-full px-4 py-3 bg-[var(--color-bg-tertiary)] border border-[var(--color-border-default)] rounded-xl text-[var(--color-text-primary)] focus:outline-none focus:border-[var(--color-accent-blue)] focus:ring-1 focus:ring-[var(--color-accent-blue)] transition-colors duration-200 appearance-none"
                  >
                    <option value="" disabled selected>Select a subject</option>
                    <option value="general">General Inquiry</option>
                    <option value="bug">Bug Report</option>
                    <option value="feature">Feature Request</option>
                    <option value="feedback">Feedback</option>
                    <option value="partnership">Partnership</option>
                    <option value="other">Other</option>
                  </select>
                  <p id="contact-subject-error" class="text-[var(--color-accent-pink)] text-xs mt-1 hidden">Please select a subject.</p>
                </div>

                <div>
                  <label for="contact-message" class="block text-sm font-medium text-[var(--color-text-secondary)] mb-2">
                    Message <span class="text-[var(--color-accent-pink)]">*</span>
                  </label>
                  <textarea
                    id="contact-message"
                    name="message"
                    required
                    rows="5"
                    placeholder="Tell us what's on your mind..."
                    class="w-full px-4 py-3 bg-[var(--color-bg-tertiary)] border border-[var(--color-border-default)] rounded-xl text-[var(--color-text-primary)] placeholder:text-[var(--color-text-muted)] focus:outline-none focus:border-[var(--color-accent-blue)] focus:ring-1 focus:ring-[var(--color-accent-blue)] transition-colors duration-200 resize-y min-h-[120px]"
                  ></textarea>
                  <p id="contact-message-error" class="text-[var(--color-accent-pink)] text-xs mt-1 hidden">Please enter your message (at least 10 characters).</p>
                </div>

                <button
                  type="submit"
                  id="contact-submit-btn"
                  class="btn-primary w-full py-3.5 text-base"
                >
                  Send Message
                  <span aria-hidden="true">→</span>
                </button>
              </form>

              <!-- Success Message -->
              <div id="contact-success" class="hidden text-center py-12">
                <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-[var(--color-accent-emerald)]/10 mb-6 animate-[scale-in_0.4s_var(--ease-out-expo)_forwards]">
                  <svg class="w-10 h-10 text-[var(--color-accent-emerald)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
                <h3 class="text-2xl font-bold text-[var(--color-text-primary)] mb-3 animate-[slide-up_0.5s_var(--ease-out-expo)_0.1s_forwards] opacity-0">
                  Message received!
                </h3>
                <p class="text-[var(--color-text-secondary)] max-w-sm mx-auto mb-6 animate-[slide-up_0.5s_var(--ease-out-expo)_0.2s_forwards] opacity-0">
                  Thank you for reaching out. Your message has been saved and we appreciate your feedback. Keep building great things with NextFolios!
                </p>
                <button
                  id="contact-send-another"
                  class="btn-secondary animate-[slide-up_0.5s_var(--ease-out-expo)_0.3s_forwards] opacity-0"
                >
                  Send another message
                </button>
              </div>
            </div>
          </div>

          <!-- Sidebar -->
          <div class="lg:col-span-2 space-y-6">
            <!-- Response Time -->
            <div class="card p-6" id="contact-response-info">
              <h3 class="font-semibold text-[var(--color-text-primary)] mb-3 flex items-center gap-2">
                <span aria-hidden="true">⏱️</span>
                Response Time
              </h3>
              <p class="text-[var(--color-text-secondary)] text-sm leading-relaxed">
                We aim to respond to all inquiries within 48 hours. Bug reports and urgent issues are prioritized. Feature requests are reviewed weekly and added to our public roadmap when applicable.
              </p>
            </div>

            <!-- What to Include -->
            <div class="card p-6" id="contact-tips">
              <h3 class="font-semibold text-[var(--color-text-primary)] mb-3 flex items-center gap-2">
                <span aria-hidden="true">💡</span>
                Tips for Faster Help
              </h3>
              <ul class="text-[var(--color-text-secondary)] text-sm space-y-2">
                <li class="flex items-start gap-2">
                  <span class="text-[var(--color-accent-blue)] mt-1 shrink-0">•</span>
                  <span>For bug reports, include your browser name, OS, and steps to reproduce the issue.</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-[var(--color-accent-blue)] mt-1 shrink-0">•</span>
                  <span>For feature requests, describe the problem you are trying to solve, not just the solution you imagine.</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-[var(--color-accent-blue)] mt-1 shrink-0">•</span>
                  <span>Include screenshots or screen recordings if you can — they help us understand issues faster.</span>
                </li>
              </ul>
            </div>

            <!-- Social Links -->
            <div class="card p-6" id="contact-social-links">
              <h3 class="font-semibold text-[var(--color-text-primary)] mb-4 flex items-center gap-2">
                <span aria-hidden="true">🌐</span>
                Connect With Us
              </h3>
              <div class="space-y-3">
                <a
                  href="https://github.com/nextfolios"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-3 text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors duration-200 group"
                  id="contact-link-github"
                >
                  <div class="w-10 h-10 rounded-lg bg-[var(--color-bg-tertiary)] flex items-center justify-center group-hover:bg-[var(--color-bg-elevated)] transition-colors">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                  </div>
                  <div>
                    <div class="text-sm font-medium">GitHub</div>
                    <div class="text-xs text-[var(--color-text-muted)]">Star us & contribute</div>
                  </div>
                </a>

                <a
                  href="https://twitter.com/nextfolios"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-3 text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors duration-200 group"
                  id="contact-link-twitter"
                >
                  <div class="w-10 h-10 rounded-lg bg-[var(--color-bg-tertiary)] flex items-center justify-center group-hover:bg-[var(--color-bg-elevated)] transition-colors">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                  </div>
                  <div>
                    <div class="text-sm font-medium">X (Twitter)</div>
                    <div class="text-xs text-[var(--color-text-muted)]">Updates & announcements</div>
                  </div>
                </a>

                <a
                  href="https://linkedin.com/company/nextfolios"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-3 text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors duration-200 group"
                  id="contact-link-linkedin"
                >
                  <div class="w-10 h-10 rounded-lg bg-[var(--color-bg-tertiary)] flex items-center justify-center group-hover:bg-[var(--color-bg-elevated)] transition-colors">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                  </div>
                  <div>
                    <div class="text-sm font-medium">LinkedIn</div>
                    <div class="text-xs text-[var(--color-text-muted)]">Professional network</div>
                  </div>
                </a>

                <a
                  href="mailto:hello@nextfolios.com"
                  class="flex items-center gap-3 text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors duration-200 group"
                  id="contact-link-email"
                >
                  <div class="w-10 h-10 rounded-lg bg-[var(--color-bg-tertiary)] flex items-center justify-center group-hover:bg-[var(--color-bg-elevated)] transition-colors">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                  </div>
                  <div>
                    <div class="text-sm font-medium">hello@nextfolios.com</div>
                    <div class="text-xs text-[var(--color-text-muted)]">Direct email</div>
                  </div>
                </a>
              </div>
            </div>

            <!-- FAQ callout -->
            <div class="card p-6 border-[var(--color-accent-blue)]/20" id="contact-faq-callout">
              <h3 class="font-semibold text-[var(--color-text-primary)] mb-2">Check our FAQ first</h3>
              <p class="text-[var(--color-text-secondary)] text-sm mb-4">
                Many common questions are already answered in our comprehensive FAQ section.
              </p>
              <a href="/faq" class="btn-secondary text-sm py-2 px-4">
                View FAQ
                <span aria-hidden="true">→</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Additional Info -->
    <section class="py-16 bg-[var(--color-bg-secondary)]" id="contact-info-section">
      <div class="section-container">
        <div class="max-w-4xl mx-auto">
          <div class="prose">
            <h2>How We Handle Your Messages</h2>
            <p>
              When you submit a message through this form, it is stored locally in your browser's storage. This is a deliberate privacy-first design decision. We do not transmit your message to any external server, database, or third-party service through this form. Your message stays on your device unless you choose to email us directly at <a href="mailto:hello@nextfolios.com">hello@nextfolios.com</a>.
            </p>
            <p>
              We built the contact form this way to demonstrate our commitment to privacy while still providing a familiar contact experience. If you need a guaranteed response, we recommend reaching out via email or through our social media channels listed above. We actively monitor all our channels and prioritize responding to bug reports and accessibility issues.
            </p>
            <p>
              For partnership inquiries, press requests, or business-related conversations, please email us directly and include "Partnership" or "Press" in your subject line so we can route your message to the right person. We are open to collaborations that align with our mission of making career tools accessible to everyone.
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const successEl = document.getElementById('contact-success');
    const sendAnotherBtn = document.getElementById('contact-send-another');
    const submitBtn = document.getElementById('contact-submit-btn');

    if (!form || !successEl || !sendAnotherBtn || !submitBtn) return;

    const fields = [
      { id: 'contact-name', errorId: 'contact-name-error', validate: (v: string) => v.trim().length >= 2 },
      { id: 'contact-email', errorId: 'contact-email-error', validate: (v: string) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v) },
      { id: 'contact-subject', errorId: 'contact-subject-error', validate: (v: string) => v.trim().length > 0 },
      { id: 'contact-message', errorId: 'contact-message-error', validate: (v: string) => v.trim().length >= 10 },
    ];

    function showError(errorId: string) {
      const el = document.getElementById(errorId);
      if (el) el.classList.remove('hidden');
    }

    function hideError(errorId: string) {
      const el = document.getElementById(errorId);
      if (el) el.classList.add('hidden');
    }

    // Real-time validation
    fields.forEach(({ id, errorId, validate }) => {
      const input = document.getElementById(id) as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement | null;
      if (!input) return;
      input.addEventListener('blur', () => {
        if (validate(input.value)) {
          hideError(errorId);
        } else {
          showError(errorId);
        }
      });
      input.addEventListener('input', () => {
        if (validate(input.value)) {
          hideError(errorId);
        }
      });
    });

    form.addEventListener('submit', (e) => {
      e.preventDefault();

      let isValid = true;

      fields.forEach(({ id, errorId, validate }) => {
        const input = document.getElementById(id) as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement | null;
        if (!input) return;
        if (validate(input.value)) {
          hideError(errorId);
        } else {
          showError(errorId);
          isValid = false;
        }
      });

      if (!isValid) return;

      // Save to localStorage
      const submission = {
        name: (document.getElementById('contact-name') as HTMLInputElement).value.trim(),
        email: (document.getElementById('contact-email') as HTMLInputElement).value.trim(),
        subject: (document.getElementById('contact-subject') as HTMLSelectElement).value,
        message: (document.getElementById('contact-message') as HTMLTextAreaElement).value.trim(),
        timestamp: new Date().toISOString(),
      };

      try {
        const existing = JSON.parse(localStorage.getItem('nextfolios-contact-submissions') || '[]');
        existing.push(submission);
        localStorage.setItem('nextfolios-contact-submissions', JSON.stringify(existing));
      } catch {
        // Storage full or unavailable — still show success
      }

      // Show success state
      form.classList.add('hidden');
      successEl.classList.remove('hidden');
    });

    sendAnotherBtn.addEventListener('click', () => {
      form.reset();
      successEl.classList.add('hidden');
      form.classList.remove('hidden');
      fields.forEach(({ errorId }) => hideError(errorId));
    });
  });
</script>
