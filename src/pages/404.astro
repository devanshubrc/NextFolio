---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEOHead from '../components/seo/SEOHead.astro';
---

<BaseLayout>
  <SEOHead
    slot="head"
    title="Page Not Found - NextFolios"
    description="The page you are looking for does not exist or has been moved. Navigate back to NextFolios to explore our free career tools."
    noindex={true}
  />

  <main id="main-content" class="min-h-[80vh] flex items-center justify-center py-20">
    <div class="section-container">
      <div class="max-w-2xl mx-auto text-center">

        <!-- Floating ASCII Art Astronaut -->
        <div class="mb-8 animate-[float_6s_ease-in-out_infinite]" aria-hidden="true">
          <pre class="text-[var(--color-text-muted)] text-xs sm:text-sm leading-tight font-mono inline-block text-left select-none">
    .  ✦   .  ˚
  .    ★   .
        .-"-.
       /  _  \
      | (&bull; &bull;) |
       \  ▽  /
    .---'---'---.
   / |||     ||| \
  /  |||     |||  \
 |   |||     |||   |
  \  '|'     '|'  /
   '._________.'
      |  | |  |
      |  | |  |
     _|  | |  |_
    '.__.' '.__.'
          </pre>
        </div>

        <!-- 404 Number -->
        <div class="mb-6">
          <span class="text-8xl sm:text-9xl font-black tracking-tighter gradient-text leading-none">
            404
          </span>
        </div>

        <!-- Message -->
        <h1 class="text-2xl sm:text-3xl font-bold text-[var(--color-text-primary)] mb-4">
          Lost in space?
        </h1>
        <p class="text-lg text-[var(--color-text-secondary)] mb-10 max-w-md mx-auto leading-relaxed">
          The page you are looking for has drifted into another orbit. It might have been moved, renamed, or may never have existed in this dimension.
        </p>

        <!-- Action Buttons -->
        <div class="flex flex-wrap justify-center gap-4 mb-14">
          <a href="/" class="btn-primary" id="error-link-home">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
            Go Home
          </a>
          <a href="/faq" class="btn-secondary" id="error-link-faq">
            View FAQ
          </a>
        </div>

        <!-- Helpful Links Grid -->
        <div class="border-t border-[var(--color-border-default)] pt-10">
          <p class="text-sm text-[var(--color-text-muted)] mb-6 uppercase tracking-wider font-medium">
            Or try one of these
          </p>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
            <a
              href="/"
              class="card p-4 text-center group no-underline"
              id="error-nav-home"
            >
              <div class="text-2xl mb-2" aria-hidden="true">🏠</div>
              <span class="text-sm font-medium text-[var(--color-text-primary)] group-hover:text-[var(--color-text-accent)] transition-colors">Home</span>
            </a>
            <a
              href="/about"
              class="card p-4 text-center group no-underline"
              id="error-nav-about"
            >
              <div class="text-2xl mb-2" aria-hidden="true">ℹ️</div>
              <span class="text-sm font-medium text-[var(--color-text-primary)] group-hover:text-[var(--color-text-accent)] transition-colors">About</span>
            </a>
            <a
              href="/faq"
              class="card p-4 text-center group no-underline"
              id="error-nav-faq"
            >
              <div class="text-2xl mb-2" aria-hidden="true">❓</div>
              <span class="text-sm font-medium text-[var(--color-text-primary)] group-hover:text-[var(--color-text-accent)] transition-colors">FAQ</span>
            </a>
            <a
              href="/contact"
              class="card p-4 text-center group no-underline"
              id="error-nav-contact"
            >
              <div class="text-2xl mb-2" aria-hidden="true">✉️</div>
              <span class="text-sm font-medium text-[var(--color-text-primary)] group-hover:text-[var(--color-text-accent)] transition-colors">Contact</span>
            </a>
          </div>
        </div>

        <!-- Random fun messages -->
        <p class="text-[var(--color-text-muted)] text-xs mt-10 italic" id="error-fun-message">
          "Not all who wander are lost — but this URL definitely is."
        </p>

      </div>
    </div>
  </main>
</BaseLayout>

<script>
  const messages = [
    "Not all who wander are lost — but this URL definitely is.",
    "We searched every server. This page was not on any of them.",
    "Houston, we have a 404.",
    "This page went on vacation and forgot to leave a forwarding address.",
    "You have discovered the void between web pages. Congratulations?",
    "The bits that made up this page have been recycled into something better.",
  ];
  const el = document.getElementById('error-fun-message');
  if (el) {
    el.textContent = `"${messages[Math.floor(Math.random() * messages.length)]}"`;
  }
</script>
