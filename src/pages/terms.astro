---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEOHead from '../components/seo/SEOHead.astro';

const lastUpdated = 'July 20, 2026';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Terms & Conditions — NextFolios',
  description: 'Terms and conditions governing the use of NextFolios career tools and services.',
  url: 'https://nextfolios.com/terms',
  dateModified: '2026-07-20',
};
