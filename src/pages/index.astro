---
/**
 * index.astro — NextFolios Home Page
 * The main landing page showcasing all tools, features, and value proposition
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import SEOHead from '../components/seo/SEOHead.astro';

const tools = [
  {
    icon: '📄',
    title: 'ATS Resume Checker',
    description: 'Upload your resume and get instant ATS compatibility analysis with keyword matching and optimization tips.',
    href: '/tools/ats-resume-checker/',
    gradient: 'from-blue-500 to-cyan-400',
  },
  {
    icon: '🏗️',
    title: 'Resume Builder',
    description: 'Create professional resumes with beautiful templates. Live preview, PDF download, and print support.',
    href: '/tools/resume-builder/',
    gradient: 'from-purple-500 to-pink-400',
  },
  {
    icon: '📊',
    title: 'Resume Score',
    description: 'Get a detailed quality score for your resume with category breakdowns and improvement suggestions.',
    href: '/tools/resume-score/',
    gradient: 'from-emerald-500 to-teal-400',
  },
  {
    icon: '🎨',
    title: 'Portfolio Generator',
    description: 'Generate stunning portfolio websites instantly. Choose from templates and export clean HTML code.',
    href: '/tools/portfolio-generator/',
    gradient: 'from-orange-500 to-amber-400',
  },
  {
    icon: '💰',
    title: 'Salary Estimator',
    description: 'Estimate salaries based on your role, experience level, and location with interactive visualizations.',
    href: '/tools/salary-estimator/',
    gradient: 'from-green-500 to-emerald-400',
  },
  {
    icon: '❓',
    title: 'Interview Questions',
    description: 'Access curated interview questions with categories, difficulty filters, and practice modes.',
    href: '/tools/interview-question-generator/',
    gradient: 'from-indigo-500 to-blue-400',
  },
  {
    icon: '🗺️',
    title: 'Career Roadmap',
    description: 'Explore interactive career paths with skill requirements, learning resources, and progress tracking.',
    href: '/tools/career-roadmap/',
    gradient: 'from-rose-500 to-pink-400',
  },
  {
    icon: '🎯',
    title: 'Skill Gap Analyzer',
    description: 'Identify skill gaps between your current abilities and target roles with personalized learning plans.',
    href: '/tools/skill-gap-analyzer/',
    gradient: 'from-violet-500 to-purple-400',
  },
];

const features = [
  {
    icon: '🔓',
    title: 'No Login Required',
    description: 'Start using any tool instantly. No accounts, no sign-ups, no barriers.',
  },
  {
    icon: '🆓',
    title: '100% Free Forever',
    description: 'All tools are completely free. No hidden charges, no premium walls.',
  },
  {
    icon: '🔒',
    title: 'Privacy First',
    description: 'Everything runs in your browser. Your data never leaves your device.',
  },
  {
    icon: '⚡',
    title: 'Lightning Fast',
    description: 'Built with modern web technology for instant results and smooth performance.',
  },
  {
    icon: '📱',
    title: 'Works Everywhere',
    description: 'Fully responsive design that works on mobile, tablet, and desktop.',
  },
  {
    icon: '🌙',
    title: 'Dark & Light Mode',
    description: 'Choose your preferred theme for comfortable viewing any time of day.',
  },
];

const stats = [
  { value: '8+', label: 'Career Tools' },
  { value: '100%', label: 'Free & Open' },
  { value: '0', label: 'Data Sent to Server' },
  { value: '95+', label: 'Lighthouse Score' },
];

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "NextFolios",
  "url": "https://nextfolios.com",
  "description": "The Ultimate AI Career Toolkit — Build better resumes, optimize for ATS, create professional portfolios, estimate salaries, prepare for interviews, and accelerate career growth.",
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Web",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};
---
<BaseLayout>
  <SEOHead
    slot="head"
    title="NextFolios — The Ultimate Free Career Toolkit"
    description="Build better resumes, optimize for ATS, create professional portfolios, estimate salaries, prepare for interviews, and accelerate career growth. 100% free, no sign-up required."
    schema={schema}
  />

  <main id="main-content">
    <!-- ===== HERO SECTION ===== -->
    <section class="relative overflow-hidden py-24 md:py-32 lg:py-40" aria-labelledby="hero-title">
      <!-- Animated gradient background orbs -->
      <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
        <div class="absolute top-[-20%] left-[10%] w-[500px] h-[500px] rounded-full opacity-15 blur-[100px]" 
          style="background: var(--color-gradient-start); animation: float 8s ease-in-out infinite;"></div>
        <div class="absolute top-[10%] right-[-5%] w-[400px] h-[400px] rounded-full opacity-10 blur-[100px]" 
          style="background: var(--color-gradient-mid); animation: float 10s ease-in-out infinite 2s;"></div>
        <div class="absolute bottom-[-10%] left-[30%] w-[600px] h-[600px] rounded-full opacity-10 blur-[120px]" 
          style="background: var(--color-gradient-end); animation: float 12s ease-in-out infinite 4s;"></div>
        
        <!-- Grid pattern overlay -->
        <div class="absolute inset-0 opacity-[0.03]"
          style="background-image: linear-gradient(rgba(255,255,255,0.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.1) 1px, transparent 1px); background-size: 60px 60px;">
        </div>
      </div>

      <div class="section-container relative z-10 text-center">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 badge mb-8" style="animation: var(--animate-fade-in); animation-delay: 100ms; opacity: 0;">
          <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
          <span>Free & Open Source Career Platform</span>
        </div>

        <!-- Title -->
        <h1 id="hero-title" class="text-5xl md:text-6xl lg:text-7xl xl:text-8xl font-extrabold tracking-tight mb-6 leading-[1.1]"
          style="animation: var(--animate-slide-up); animation-delay: 200ms; opacity: 0;">
          Build Your Next Career,<br />
          <span class="gradient-text">Faster.</span>
        </h1>

        <!-- Subtitle -->
        <p class="text-lg md:text-xl lg:text-2xl max-w-3xl mx-auto mb-10 leading-relaxed"
          style="color: var(--color-text-secondary); animation: var(--animate-slide-up); animation-delay: 400ms; opacity: 0;">
          The ultimate free career toolkit. Build resumes, optimize for ATS, create portfolios, estimate salaries, and prepare for interviews — all in one place, no sign-up required.
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-wrap gap-4 justify-center" style="animation: var(--animate-slide-up); animation-delay: 600ms; opacity: 0;">
          <a href="#tools" class="btn-primary text-base px-8 py-3.5">
            Explore Tools
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
          </a>
          <a href="/tools/ats-resume-checker/" class="btn-secondary text-base px-8 py-3.5">
            Try ATS Checker
          </a>
        </div>

        <!-- Stats Row -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mt-16 md:mt-20 max-w-3xl mx-auto"
          style="animation: var(--animate-fade-in); animation-delay: 800ms; opacity: 0;">
          {stats.map(stat => (
            <div class="text-center">
              <div class="text-3xl md:text-4xl font-bold gradient-text mb-1">{stat.value}</div>
              <div class="text-sm" style="color: var(--color-text-muted);">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== TOOLS SECTION ===== -->
    <section id="tools" class="py-20 md:py-28" aria-labelledby="tools-title" style="background: var(--color-bg-secondary);">
      <div class="section-container">
        <div class="text-center mb-14">
          <div class="badge mb-4 inline-flex">🛠️ Career Tools</div>
          <h2 id="tools-title" class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight mb-4" style="color: var(--color-text-primary);">
            Everything You Need to <span class="gradient-text">Succeed</span>
          </h2>
          <p class="text-lg max-w-2xl mx-auto" style="color: var(--color-text-secondary);">
            Powerful, free tools designed to help you stand out in your job search and accelerate your career growth.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">
          {tools.map((tool, i) => (
            <a href={tool.href} 
              class="group card p-6 flex flex-col"
              style={`animation: var(--animate-slide-up); animation-delay: ${200 + i * 100}ms; opacity: 0;`}
              id={`tool-card-${tool.href.split('/').filter(Boolean).pop()}`}>
              
              {/* Icon with gradient background */}
              <div class={`w-12 h-12 rounded-xl flex items-center justify-center text-2xl mb-4 bg-gradient-to-br ${tool.gradient} bg-opacity-10`}
                style="background: linear-gradient(135deg, rgba(99,102,241,0.1), rgba(168,85,247,0.1));">
                {tool.icon}
              </div>
              
              <h3 class="text-lg font-semibold mb-2 group-hover:text-[var(--color-text-accent)] transition-colors" style="color: var(--color-text-primary);">
                {tool.title}
              </h3>
              
              <p class="text-sm leading-relaxed flex-grow" style="color: var(--color-text-muted);">
                {tool.description}
              </p>
              
              <div class="mt-4 flex items-center gap-1.5 text-sm font-medium text-[var(--color-text-accent)] opacity-0 group-hover:opacity-100 transition-opacity duration-200">
                Try it free
                <svg class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== FEATURES SECTION ===== -->
    <section class="py-20 md:py-28" aria-labelledby="features-title">
      <div class="section-container">
        <div class="text-center mb-14">
          <div class="badge mb-4 inline-flex">✨ Why NextFolios</div>
          <h2 id="features-title" class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight mb-4" style="color: var(--color-text-primary);">
            Built Different, <span class="gradient-text">For You</span>
          </h2>
          <p class="text-lg max-w-2xl mx-auto" style="color: var(--color-text-secondary);">
            No sign-ups, no servers, no BS. Just fast, free tools that work right in your browser.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
          {features.map((feature, i) => (
            <div class="card p-6"
              style={`animation: var(--animate-slide-up); animation-delay: ${200 + i * 100}ms; opacity: 0;`}>
              <div class="text-3xl mb-4">{feature.icon}</div>
              <h3 class="text-lg font-semibold mb-2" style="color: var(--color-text-primary);">{feature.title}</h3>
              <p class="text-sm leading-relaxed" style="color: var(--color-text-muted);">{feature.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== HOW IT WORKS SECTION ===== -->
    <section class="py-20 md:py-28" aria-labelledby="how-title" style="background: var(--color-bg-secondary);">
      <div class="section-container max-w-4xl">
        <div class="text-center mb-14">
          <div class="badge mb-4 inline-flex">🚀 Simple Process</div>
          <h2 id="how-title" class="text-3xl md:text-4xl font-bold tracking-tight mb-4" style="color: var(--color-text-primary);">
            How It Works
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {[
            { step: '01', title: 'Choose a Tool', desc: 'Pick from our suite of 8+ career tools based on what you need right now.' },
            { step: '02', title: 'Use It Instantly', desc: 'No sign-up needed. Just start using the tool right in your browser — everything runs locally.' },
            { step: '03', title: 'Get Results', desc: 'Download your resume, view your score, export your portfolio — all in seconds.' },
          ].map((item, i) => (
            <div class="relative text-center md:text-left">
              <div class="text-5xl font-extrabold mb-4 gradient-text opacity-30">{item.step}</div>
              <h3 class="text-xl font-semibold mb-2" style="color: var(--color-text-primary);">{item.title}</h3>
              <p class="text-sm leading-relaxed" style="color: var(--color-text-muted);">{item.desc}</p>
              {i < 2 && (
                <div class="hidden md:block absolute top-8 right-[-16%] text-2xl" style="color: var(--color-text-muted);" aria-hidden="true">→</div>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== CTA SECTION ===== -->
    <section class="py-20 md:py-28" aria-labelledby="cta-title">
      <div class="section-container">
        <div class="relative overflow-hidden rounded-2xl p-10 md:p-16 text-center"
          style="background: linear-gradient(135deg, rgba(99, 102, 241, 0.08), rgba(168, 85, 247, 0.08), rgba(236, 72, 153, 0.08));">
          
          {/* Decorative gradient orbs */}
          <div class="absolute top-0 right-0 w-[300px] h-[300px] opacity-20 blur-[80px] pointer-events-none"
            style="background: var(--color-gradient-mid);"></div>
          <div class="absolute bottom-0 left-0 w-[200px] h-[200px] opacity-15 blur-[60px] pointer-events-none"
            style="background: var(--color-gradient-start);"></div>
          
          <div class="relative z-10">
            <h2 id="cta-title" class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight mb-4" style="color: var(--color-text-primary);">
              Ready to Build Your <span class="gradient-text">Dream Career?</span>
            </h2>
            <p class="text-lg max-w-2xl mx-auto mb-8" style="color: var(--color-text-secondary);">
              Join thousands of job seekers using NextFolios to land their dream jobs. All tools are free, forever.
            </p>
            <div class="flex flex-wrap gap-4 justify-center">
              <a href="/tools/ats-resume-checker/" class="btn-primary text-base px-8 py-3.5">
                Get Started — It's Free
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
