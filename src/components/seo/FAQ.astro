---
/**
 * FAQ.astro — Accordion FAQ section with FAQPage JSON-LD schema.
 *
 * Renders expandable FAQ items using native `<details>` / `<summary>` elements
 * and injects FAQPage structured data for SEO.
 *
 * @example
 * ```astro
 * <FAQ items={[
 *   { question: "Is it free?", answer: "Yes, completely free." },
 *   { question: "Do I need to sign up?", answer: "No account required." },
 * ]} />
 * ```
 */

interface Props {
  /** Array of FAQ question/answer pairs */
  items: { question: string; answer: string }[];
  /** Section heading — defaults to 'Frequently Asked Questions' */
  title?: string;
}

const { items, title = 'Frequently Asked Questions' } = Astro.props;

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

<section class="w-full max-w-3xl mx-auto py-16 px-4" id="faq">
  <h2 class="text-3xl font-bold text-[var(--color-text-primary)] text-center mb-10">
    {title}
  </h2>

  <div class="space-y-3">
    {items.map((item, index) => (
      <details
        class="group bg-[var(--color-bg-secondary)] border border-[var(--color-border-default)] rounded-2xl overflow-hidden transition-all duration-300 hover:border-[var(--color-border-hover)]"
      >
        <summary class="flex items-center justify-between cursor-pointer px-6 py-5 text-[var(--color-text-primary)] font-medium text-lg select-none list-none [&::-webkit-details-marker]:hidden">
          <span class="pr-4">{item.question}</span>
          <span class="shrink-0 text-[var(--color-text-muted)] transition-transform duration-300 group-open:rotate-45 text-2xl leading-none">
            +
          </span>
        </summary>
        <div class="px-6 pb-5 text-[var(--color-text-secondary)] leading-relaxed border-t border-[var(--color-border-default)] pt-4">
          {item.answer}
        </div>
      </details>
    ))}
  </div>
</section>

<!-- JSON-LD: FAQPage -->
<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
