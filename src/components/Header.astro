---
/**
 * Header.astro — Premium sticky navigation with glassmorphism
 * Features: Logo, nav links, tools dropdown, theme toggle, mobile menu, search trigger
 */
const navLinks = [
  { label: 'Tools', href: '/#tools', hasDropdown: true },
  { label: 'Blog', href: '/blog/' },
  { label: 'About', href: '/about/' },
  { label: 'FAQ', href: '/faq/' },
  { label: 'Contact', href: '/contact/' },
];

const toolLinks = [
  { label: '📄 ATS Resume Checker', href: '/tools/ats-resume-checker/', desc: 'Check your resume against ATS systems' },
  { label: '🏗️ Resume Builder', href: '/tools/resume-builder/', desc: 'Build professional resumes' },
  { label: '📊 Resume Score', href: '/tools/resume-score/', desc: 'Get your resume quality score' },
  { label: '🎨 Portfolio Generator', href: '/tools/portfolio-generator/', desc: 'Create stunning portfolios' },
  { label: '💰 Salary Estimator', href: '/tools/salary-estimator/', desc: 'Estimate salaries by role & location' },
  { label: '❓ Interview Questions', href: '/tools/interview-question-generator/', desc: 'Practice with curated questions' },
  { label: '🗺️ Career Roadmap', href: '/tools/career-roadmap/', desc: 'Plan your career path' },
  { label: '🎯 Skill Gap Analyzer', href: '/tools/skill-gap-analyzer/', desc: 'Find your skill gaps' },
];

const currentPath = Astro.url.pathname;
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-[100] transition-all duration-300">
  <div class="glass">
    <div class="section-container">
      <nav class="flex items-center justify-between h-16 md:h-18" aria-label="Main navigation">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2.5 group" aria-label="NextFolios Home">
          <div class="w-8 h-8 rounded-lg flex items-center justify-center text-white font-bold text-sm" 
            style="background: linear-gradient(135deg, var(--color-gradient-start), var(--color-gradient-mid));">
            N
          </div>
          <span class="text-lg font-bold tracking-tight" style="color: var(--color-text-primary);">
            Next<span class="gradient-text">Folios</span>
          </span>
        </a>

        <!-- Desktop Navigation -->
        <div class="hidden lg:flex items-center gap-1">
          {navLinks.map(link => (
            <div class={`relative ${link.hasDropdown ? 'group' : ''}`}>
              <a 
                href={link.href}
                class={`px-3.5 py-2 rounded-lg text-sm font-medium transition-colors duration-200
                  ${currentPath.startsWith(link.href.replace('/#tools', '/tools/')) 
                    ? 'text-[var(--color-text-accent)] bg-[rgba(99,102,241,0.1)]' 
                    : 'text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:bg-[var(--color-bg-tertiary)]'
                  }`}
                aria-current={currentPath === link.href ? 'page' : undefined}
              >
                {link.label}
                {link.hasDropdown && (
                  <svg class="inline-block ml-1 w-3.5 h-3.5 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                )}
              </a>
              
              {/* Tools Dropdown */}
              {link.hasDropdown && (
                <div class="absolute top-full left-1/2 -translate-x-1/2 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
                  <div class="w-[420px] p-3 rounded-xl shadow-elevated" 
                    style="background: var(--color-bg-elevated); border: 1px solid var(--color-border-default);">
                    <div class="grid grid-cols-1 gap-0.5">
                      {toolLinks.map(tool => (
                        <a href={tool.href} 
                          class="flex items-start gap-3 p-2.5 rounded-lg transition-colors duration-150 hover:bg-[var(--color-bg-tertiary)] group/item">
                          <span class="text-lg mt-0.5 shrink-0">{tool.label.split(' ')[0]}</span>
                          <div>
                            <div class="text-sm font-medium" style="color: var(--color-text-primary);">
                              {tool.label.split(' ').slice(1).join(' ')}
                            </div>
                            <div class="text-xs mt-0.5" style="color: var(--color-text-muted);">
                              {tool.desc}
                            </div>
                          </div>
                        </a>
                      ))}
                    </div>
                  </div>
                </div>
              )}
            </div>
          ))}
        </div>

        <!-- Right Actions -->
        <div class="flex items-center gap-2">
          <!-- Search Trigger -->
          <button 
            id="search-trigger"
            class="flex items-center gap-2 px-3 py-1.5 rounded-lg text-sm transition-colors duration-200"
            style="color: var(--color-text-muted); background: var(--color-bg-tertiary); border: 1px solid var(--color-border-default);"
            aria-label="Search (Ctrl+K)"
            onclick="document.dispatchEvent(new CustomEvent('open-search'))"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <span class="hidden md:inline">Search</span>
            <kbd class="hidden md:inline-flex items-center gap-0.5 px-1.5 py-0.5 text-[10px] font-mono rounded" 
              style="background: var(--color-bg-primary); color: var(--color-text-muted);">
              ⌘K
            </kbd>
          </button>

          <!-- Theme Toggle -->
          <button
            id="theme-toggle"
            class="p-2 rounded-lg transition-colors duration-200 hover:bg-[var(--color-bg-tertiary)]"
            style="color: var(--color-text-muted);"
            aria-label="Toggle dark/light mode"
          >
            <!-- Sun icon (shown in dark mode) -->
            <svg class="w-5 h-5 dark-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
            <!-- Moon icon (shown in light mode) -->
            <svg class="w-5 h-5 light-icon hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
            </svg>
          </button>

          <!-- Mobile Menu Toggle -->
          <button
            id="mobile-menu-toggle"
            class="lg:hidden p-2 rounded-lg transition-colors duration-200 hover:bg-[var(--color-bg-tertiary)]"
            style="color: var(--color-text-muted);"
            aria-label="Toggle mobile menu"
            aria-expanded="false"
          >
            <svg class="w-5 h-5 menu-open-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
            <svg class="w-5 h-5 menu-close-icon hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      </nav>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="lg:hidden fixed inset-0 top-16 z-[99] hidden" aria-label="Mobile navigation">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" id="mobile-menu-backdrop"></div>
    <div class="relative h-full overflow-y-auto p-4 max-w-sm ml-auto" style="background: var(--color-bg-primary);">
      <div class="flex flex-col gap-1 mb-6">
        {navLinks.filter(l => !l.hasDropdown).map(link => (
          <a href={link.href} class="px-4 py-3 rounded-xl text-base font-medium transition-colors duration-200 text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:bg-[var(--color-bg-tertiary)]">
            {link.label}
          </a>
        ))}
      </div>

      <div class="mb-2 px-4">
        <span class="text-xs font-semibold uppercase tracking-wider" style="color: var(--color-text-muted);">Tools</span>
      </div>
      <div class="flex flex-col gap-0.5">
        {toolLinks.map(tool => (
          <a href={tool.href} class="flex items-center gap-3 px-4 py-2.5 rounded-xl transition-colors duration-150 hover:bg-[var(--color-bg-tertiary)]">
            <span>{tool.label.split(' ')[0]}</span>
            <span class="text-sm" style="color: var(--color-text-secondary);">{tool.label.split(' ').slice(1).join(' ')}</span>
          </a>
        ))}
      </div>
    </div>
  </div>
</header>

<!-- Spacer for fixed header -->
<div class="h-16 md:h-18"></div>

<style>
  /* Header background on scroll */
  #site-header.scrolled .glass {
    background: rgba(10, 10, 15, 0.85);
    border-bottom: 1px solid var(--color-border-default);
  }
  
  :global(.light) #site-header.scrolled .glass {
    background: rgba(250, 250, 250, 0.85);
  }

  /* Light mode icon toggle */
  :global(.light) .dark-icon { display: none; }
  :global(.light) .light-icon { display: block; }
</style>

<script>
  // Header scroll effect
  const header = document.getElementById('site-header');
  if (header) {
    const onScroll = () => {
      if (window.scrollY > 20) {
        header.classList.add('scrolled');
      } else {
        header.classList.remove('scrolled');
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  // Theme toggle
  const themeToggle = document.getElementById('theme-toggle');
  if (themeToggle) {
    themeToggle.addEventListener('click', () => {
      const html = document.documentElement;
      const isLight = html.classList.contains('light');
      if (isLight) {
        html.classList.remove('light');
        html.classList.add('dark');
        localStorage.setItem('nextfolios-theme', 'dark');
      } else {
        html.classList.remove('dark');
        html.classList.add('light');
        localStorage.setItem('nextfolios-theme', 'light');
      }
    });
  }

  // Mobile menu
  const mobileToggle = document.getElementById('mobile-menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileBackdrop = document.getElementById('mobile-menu-backdrop');

  if (mobileToggle && mobileMenu) {
    const toggleMenu = () => {
      const isOpen = !mobileMenu.classList.contains('hidden');
      if (isOpen) {
        mobileMenu.classList.add('hidden');
        mobileToggle.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
        mobileToggle.querySelector('.menu-open-icon')?.classList.remove('hidden');
        mobileToggle.querySelector('.menu-close-icon')?.classList.add('hidden');
      } else {
        mobileMenu.classList.remove('hidden');
        mobileToggle.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
        mobileToggle.querySelector('.menu-open-icon')?.classList.add('hidden');
        mobileToggle.querySelector('.menu-close-icon')?.classList.remove('hidden');
      }
    };

    mobileToggle.addEventListener('click', toggleMenu);
    mobileBackdrop?.addEventListener('click', toggleMenu);
  }

  // Search shortcut (Ctrl+K / Cmd+K)
  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      document.dispatchEvent(new CustomEvent('open-search'));
    }
  });
</script>
