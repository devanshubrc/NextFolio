---
/**
 * Footer.astro — Multi-column footer with tools, company, legal links
 */

const currentYear = new Date().getFullYear();

const toolLinks = [
  { label: 'ATS Resume Checker', href: '/tools/ats-resume-checker/' },
  { label: 'Resume Builder', href: '/tools/resume-builder/' },
  { label: 'Resume Score', href: '/tools/resume-score/' },
  { label: 'Portfolio Generator', href: '/tools/portfolio-generator/' },
  { label: 'Salary Estimator', href: '/tools/salary-estimator/' },
  { label: 'Interview Questions', href: '/tools/interview-question-generator/' },
  { label: 'Career Roadmap', href: '/tools/career-roadmap/' },
  { label: 'Skill Gap Analyzer', href: '/tools/skill-gap-analyzer/' },
];

const companyLinks = [
  { label: 'About', href: '/about/' },
  { label: 'Blog', href: '/blog/' },
  { label: 'Contact', href: '/contact/' },
  { label: 'FAQ', href: '/faq/' },
];

const legalLinks = [
  { label: 'Privacy Policy', href: '/privacy-policy/' },
  { label: 'Terms & Conditions', href: '/terms/' },
];
---

<footer role="contentinfo" style="background: var(--color-bg-secondary); border-top: 1px solid var(--color-border-default);">
  <div class="section-container py-16 md:py-20">
    <!-- Top section: columns -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12 mb-12">
      
      <!-- Brand -->
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="flex items-center gap-2.5 mb-4 group">
          <div class="w-8 h-8 rounded-lg flex items-center justify-center text-white font-bold text-sm" 
            style="background: linear-gradient(135deg, var(--color-gradient-start), var(--color-gradient-mid));">
            N
          </div>
          <span class="text-lg font-bold tracking-tight" style="color: var(--color-text-primary);">
            Next<span class="gradient-text">Folios</span>
          </span>
        </a>
        <p class="text-sm leading-relaxed mb-4" style="color: var(--color-text-muted);">
          The ultimate free career toolkit. Build resumes, optimize for ATS, create portfolios, and accelerate your career growth.
        </p>
        
        <!-- Social Links -->
        <div class="flex gap-3">
          <a href="https://twitter.com/nextfolios" target="_blank" rel="noopener noreferrer" 
            class="w-9 h-9 rounded-lg flex items-center justify-center transition-colors duration-200 hover:bg-[var(--color-bg-tertiary)]" 
            style="color: var(--color-text-muted);" 
            aria-label="Follow NextFolios on Twitter">
            <svg class="w-4.5 h-4.5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
            </svg>
          </a>
          <a href="https://github.com/nextfolios" target="_blank" rel="noopener noreferrer"
            class="w-9 h-9 rounded-lg flex items-center justify-center transition-colors duration-200 hover:bg-[var(--color-bg-tertiary)]"
            style="color: var(--color-text-muted);"
            aria-label="NextFolios on GitHub">
            <svg class="w-4.5 h-4.5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
            </svg>
          </a>
          <a href="https://linkedin.com/company/nextfolios" target="_blank" rel="noopener noreferrer"
            class="w-9 h-9 rounded-lg flex items-center justify-center transition-colors duration-200 hover:bg-[var(--color-bg-tertiary)]"
            style="color: var(--color-text-muted);"
            aria-label="NextFolios on LinkedIn">
            <svg class="w-4.5 h-4.5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Tools -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider mb-4" style="color: var(--color-text-primary);">
          Tools
        </h3>
        <ul class="flex flex-col gap-2.5">
          {toolLinks.map(link => (
            <li>
              <a href={link.href} class="text-sm transition-colors duration-200 hover:text-[var(--color-text-primary)]" style="color: var(--color-text-muted);">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider mb-4" style="color: var(--color-text-primary);">
          Company
        </h3>
        <ul class="flex flex-col gap-2.5">
          {companyLinks.map(link => (
            <li>
              <a href={link.href} class="text-sm transition-colors duration-200 hover:text-[var(--color-text-primary)]" style="color: var(--color-text-muted);">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider mb-4" style="color: var(--color-text-primary);">
          Legal
        </h3>
        <ul class="flex flex-col gap-2.5">
          {legalLinks.map(link => (
            <li>
              <a href={link.href} class="text-sm transition-colors duration-200 hover:text-[var(--color-text-primary)]" style="color: var(--color-text-muted);">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom -->
    <div class="pt-8 flex flex-col md:flex-row items-center justify-between gap-4" 
      style="border-top: 1px solid var(--color-border-default);">
      <p class="text-sm" style="color: var(--color-text-muted);">
        © {currentYear} NextFolios. All rights reserved.
      </p>
      <p class="text-sm" style="color: var(--color-text-muted);">
        Built with ❤️ for job seekers everywhere.
      </p>
    </div>
  </div>
</footer>
