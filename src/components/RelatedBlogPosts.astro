---
/**
 * RelatedBlogPosts.astro — Dynamically renders related blog posts from content collections
 * Filters by matching tags, and falls back to recent posts.
 */
import { getCollection } from 'astro:content';

interface Props {
  tags?: string[];
}

const { tags = [] } = Astro.props;

// Fetch all blog posts
const allPosts = await getCollection('blog');

// Sort by date descending
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Filter by matching tags
const relatedPosts = sortedPosts.filter(post => {
  if (tags.length === 0) return false;
  return post.data.tags?.some(tag => tags.includes(tag));
});

// Backfill with other latest posts if we have less than 3
const displayPosts = [...relatedPosts];
if (displayPosts.length < 3) {
  const remaining = sortedPosts.filter(post => !displayPosts.some(p => p.id === post.id));
  displayPosts.push(...remaining.slice(0, 3 - displayPosts.length));
}
---

<div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto my-8">
  {displayPosts.map(post => (
    <article class="card p-6 flex flex-col justify-between transition-transform duration-200 hover:-translate-y-1">
      <div>
        <div class="flex items-center gap-2 text-xs mb-3" style="color: var(--color-text-muted);">
          <time datetime={post.data.pubDate.toISOString()}>
            {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
          </time>
          <span>•</span>
          <div class="flex flex-wrap gap-1">
            {post.data.tags.slice(0, 2).map(t => (
              <span class="px-1.5 py-0.5 rounded bg-[var(--color-bg-primary)] font-medium text-[var(--color-text-secondary)]">#{t}</span>
            ))}
          </div>
        </div>

        <h3 class="text-base font-bold mb-2 leading-snug">
          <a href={`/blog/${post.id}/`} class="text-[var(--color-text-primary)] hover:text-[var(--color-text-accent)] transition-colors no-underline">
            {post.data.title}
          </a>
        </h3>

        <p class="text-xs leading-relaxed mb-4" style="color: var(--color-text-muted);">
          {post.data.description}
        </p>
      </div>

      <a href={`/blog/${post.id}/`} class="text-xs font-semibold text-[var(--color-text-accent)] inline-flex items-center gap-1">
        Read Article →
      </a>
    </article>
  ))}

  {displayPosts.length === 0 && (
    <div class="col-span-3 text-center py-8 text-sm italic" style="color: var(--color-text-muted);">
      No blog posts found.
    </div>
  )}
</div>
