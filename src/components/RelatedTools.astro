---
/**
 * RelatedTools.astro — Related tools grid.
 *
 * Looks up the current tool's `relatedTools` slugs from the central
 * registry and renders a responsive card grid.
 *
 * @example
 * ```astro
 * <RelatedTools currentSlug="ats-resume-checker" />
 * ```
 */

import { getRelatedTools } from '../data/tools';

interface Props {
  /** Slug of the tool currently being viewed */
  currentSlug: string;
}

const { currentSlug } = Astro.props;
const related = getRelatedTools(currentSlug);
---

{related.length > 0 && (
  <section class="w-full max-w-5xl mx-auto py-16 px-4">
    <h2 class="text-2xl font-bold text-white text-center mb-8">
      Related Tools
    </h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {related.map((tool) => (
        <a
          href={`/${tool.slug}`}
          class="group relative bg-slate-800/50 backdrop-blur-sm border border-slate-700/50 rounded-2xl p-6 transition-all duration-300 hover:border-slate-600/50 hover:-translate-y-1 hover:shadow-xl hover:shadow-slate-900/40 focus:ring-2 focus:ring-blue-500 focus:outline-none"
        >
          {/* Gradient accent bar */}
          <div
            class={`absolute inset-x-0 top-0 h-1 rounded-t-2xl ${tool.color} opacity-60 group-hover:opacity-100 transition-opacity duration-300`}
          />

          {/* Icon */}
          <span class="text-4xl block mb-4" aria-hidden="true">
            {tool.icon}
          </span>

          {/* Title */}
          <h3 class="text-lg font-semibold text-white mb-2 group-hover:text-blue-400 transition-colors duration-200">
            {tool.title}
          </h3>

          {/* Description */}
          <p class="text-sm text-slate-400 leading-relaxed">
            {tool.description}
          </p>

          {/* Arrow indicator */}
          <span class="mt-4 inline-flex items-center text-sm font-medium text-blue-400 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
            Try it free
            <svg
              class="ml-1.5 w-4 h-4 transition-transform duration-200 group-hover:translate-x-1"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </span>
        </a>
      ))}
    </div>
  </section>
)}
